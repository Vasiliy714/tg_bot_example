# =========================================================================
# Helpers Platform — environment variables
# Copy this file to `.env` and fill in the values. NEVER commit your .env.
# =========================================================================

# ---------- General ----------
# One of: development | staging | production
APP_ENV=development
# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Human-readable release tag (e.g. git sha), used as Prometheus/label
APP_RELEASE=local

# ---------- Security ----------
# Fernet symmetric key, base64-urlsafe, 32 bytes. Generate with:
#   python scripts/generate_fernet_key.py
# You can list multiple (comma-separated) keys for key rotation. The first one
# is used for encryption; all are tried for decryption.
FERNET_KEYS=REPLACE_ME_WITH_GENERATED_KEY

# ---------- Database (PostgreSQL) ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=helpers
POSTGRES_USER=helpers
POSTGRES_PASSWORD=helpers
# Tuning
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- RabbitMQ (Celery broker) ----------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---------- Telegram bots ----------
# One token per bot. Leave empty to disable a bot in local setup.
WB_BOT_TOKEN=
OZON_BOT_TOKEN=
TASK_PLANNER_BOT_TOKEN=
NETWORK_BOT_TOKEN=

# ---------- Admin ----------
# Telegram user IDs of bot administrators, comma separated
ADMIN_TG_IDS=

# ---------- Wildberries / Ozon API ----------
WB_API_BASE_URL=https://suppliers-api.wildberries.ru
WB_STATS_API_BASE_URL=https://statistics-api.wildberries.ru
WB_FEEDBACKS_API_BASE_URL=https://feedbacks-api.wildberries.ru
WB_CONTENT_API_BASE_URL=https://content-api.wildberries.ru
WB_ADVERT_API_BASE_URL=https://advert-api.wildberries.ru
OZON_API_BASE_URL=https://api-seller.ozon.ru
OZON_PERFORMANCE_API_BASE_URL=https://performance.ozon.ru:443

# HTTP client tuning
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_CONNECTIONS_PER_HOST=20

# ---------- FastAPI (admin_api) ----------
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=8000
ADMIN_API_WORKERS=2

# ---------- Observability ----------
METRICS_HOST=0.0.0.0
METRICS_PORT=9100
# JSON logs are recommended in production, human-readable in development
LOG_FORMAT=json
