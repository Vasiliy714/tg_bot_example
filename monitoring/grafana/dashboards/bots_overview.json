{
  "annotations": { "list": [] },
  "editable": false,
  "schemaVersion": 39,
  "title": "Helpers Platform — Bots Overview",
  "tags": ["helpers", "bots"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Telegram updates rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (bot, outcome) (rate(telegram_updates_total[5m]))",
          "legendFormat": "{{bot}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Update handler latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (bot, le) (rate(telegram_update_latency_seconds_bucket[5m])))",
          "legendFormat": "{{bot}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Outbound HTTP errors (4xx/5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (service, status) (rate(http_client_requests_total{status=~\"4..|5..\"}[5m]))",
          "legendFormat": "{{service}} / {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Celery task latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (task, le) (rate(celery_task_latency_seconds_bucket[10m])))",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ],
  "version": 1
}
